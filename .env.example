# Адрес Frigate
FRIGATE_URL=http://localhost:5000

# MQTT брокер
MQTT_HOST=localhost
MQTT_PORT=1883

# Telegram бот
TELEGRAM_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=["123456789","987654321"]

# Настройки уведомлений (опционально)
NOTIFICATIONS__DETECTION__MIN_SCORE=0.70
NOTIFICATIONS__DETECTION__LABELS=["person","car"]
NOTIFICATIONS__DETECTION__SEND_SNAPSHOT=true
NOTIFICATIONS__DETECTION__CAMERAS=["cam1","cam2"]  # пусто = все камеры
